# Images to scan (with per-image registry credentials)
STRAPI_IMAGE=registry.gitlab.com/your-group/your-project/strapi:latest
STRAPI_REGISTRY_URL=registry.gitlab.com
STRAPI_REGISTRY_USER=gitlab+deploy-token-XXXXX
STRAPI_REGISTRY_PASS=gldt-XXXXX

FRONTEND_IMAGE=registry.gitlab.com/your-group/your-project/frontend:dev
FRONTEND_REGISTRY_URL=registry.gitlab.com
FRONTEND_REGISTRY_USER=gitlab+deploy-token-XXXXX
FRONTEND_REGISTRY_PASS=gldt-XXXXX

# Auth
AUTH_USER=admin
AUTH_PASS=changeme

# Server port
PORT=4000

# Cron schedules
SCAN_CRON=0 6 * * *
WEEKLY_CRON=0 7 * * 1

# Discord webhook for vulnerability alerts
DISCORD_WEBHOOK=https://discord.com/api/webhooks/XXXXX/XXXXX
DISCORD_MENTION=your-discord-user-id
