# Docker images to scan
FRONTEND_IMAGE=registry.gitlab.com/your-group/tyls-frontend/frontend:latest
STRAPI_IMAGE=registry.gitlab.com/your-group/tyls/strapi:latest

# GitLab registry credentials (deploy token with read_registry scope)
REGISTRY_URL=registry.gitlab.com
REGISTRY_USER=gitlab+deploy-token-XXXXX
REGISTRY_PASSWORD=gldt-XXXXX

# Server port
PORT=4000
